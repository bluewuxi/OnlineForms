{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node", "aws-lambda"]
  },
  "include": ["services/**/*.ts", "shared/**/*.ts", "tests/**/*.ts"]
}
