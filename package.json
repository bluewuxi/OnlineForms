{
  "name": "onlineforms",
  "version": "0.1.0",
  "private": true,
  "description": "OnlineForms MVP backend scaffold",
  "files": [
    "dist/**/*",
    "package.json",
    "package-lock.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "seed:sample": "node scripts/seed-sample-data.js",
    "migrate:tenant-profiles": "node scripts/migrate-tenant-profiles.js",
    "migrate:role-rename": "node scripts/migrate-role-rename.js",
    "reconcile:projections": "node scripts/reconcile-public-projections.js"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/lib-dynamodb": "^3.883.0",
    "@aws-sdk/s3-presigned-post": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "aws-jwt-verify": "^5.1.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^24.3.1",
    "typescript": "^5.9.2"
  }
}
